	local function getPlayerWithKnife()
		for _, plr in ipairs(Players:GetPlayers()) do
			if plr == player then continue end
			local char = plr.Character
			local bp   = plr:FindFirstChild("Backpack")
			if (char and char:FindFirstChild("Knife")) or (bp and bp:FindFirstChild("Knife")) then
				return plr
			end
		end
		return nil
	end

	local function getPlayerWithGun()
		for _, plr in ipairs(Players:GetPlayers()) do
			if plr == player then continue end
			local char = plr.Character
			local bp   = plr:FindFirstChild("Backpack")
			if (char and char:FindFirstChild("Gun")) or (bp and bp:FindFirstChild("Gun")) then
				return plr
			end
		end
		return nil
	end

	local function teleportTo(plr)
		if plr and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
			local hrp = getHRP()
			if hrp then
				hrp.CFrame = plr.Character.HumanoidRootPart.CFrame + Vector3.new(0,3,0)
			end
		end
	end

	makeQuickButton("Murder", function()
		local p = getPlayerWithKnife()
		if p then teleportTo(p) else print("No se encontro al asesino") end
	end, 1)
	makeQuickButton("Sheriff", function()
		local p = getPlayerWithGun()
		if p then teleportTo(p) else print("No se encontro al sheriff") end
	end, 2)
	makeQuickButton("Arma (Sheriff)", function()
		local p = getPlayerWithGun()
		if p and p.Character then
			local gun = p.Character:FindFirstChild("Gun") or (p.Character:FindFirstChild("Backpack") and p.Character:FindFirstChild("Backpack"):FindFirstChild("Gun"))
			if gun and gun:IsA("Tool") and gun:FindFirstChild("Handle") then
				local hrp = getHRP()
				if hrp then hrp.CFrame = gun.Handle.CFrame + Vector3.new(0,2,0) end
			end
		else
			print("Arma no encontrada")
		end
	end, 3)

