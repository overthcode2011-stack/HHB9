	styleCorner(codeWrapper, UDim.new(0,10))
	local codeStroke = Instance.new("UIStroke")
	codeStroke.Color = th.accent
	codeStroke.Thickness = 1
	codeStroke.Transparency = 0.65
	codeStroke.Parent = codeWrapper
	table.insert(reg.accentStrokes, codeStroke)

	local lineNumBg = Instance.new("Frame")
	lineNumBg.Size = UDim2.new(0,30,1,0)
