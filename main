--============================================================
-- ✅ MEJORA 7: Toast de notificación (definido antes de Settings)
--============================================================
local function showToast(msg)
	local toast = Instance.new("TextLabel")
	toast.Size = UDim2.new(0, 220, 0, 36)
	toast.Position = UDim2.new(0.5, -110, 1, -60)
	toast.BackgroundColor3 = T().accent
	toast.BackgroundTransparency = 0.1
	toast.TextColor3 = T().bg
	toast.Text = msg
	toast.Font = Enum.Font.GothamBold
	toast.TextSize = 13
	toast.BorderSizePixel = 0
	toast.ZIndex = 100
	toast.Parent = screenGui
	styleCorner(toast, UDim.new(0, 8))
	TweenService:Create(toast, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {BackgroundTransparency = 0}):Play()
	task.delay(1.8, function()
		TweenService:Create(toast, TweenInfo.new(0.4), {
			BackgroundTransparency = 1,
			Position = UDim2.new(0.5, -110, 1, -40)
		}):Play()
		task.delay(0.4, function() if toast and toast.Parent then toast:Destroy() end end)
	end)
end

