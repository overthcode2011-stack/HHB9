	clearBtnLbl.Position = UDim2.new(0,34,0,0)
	clearBtnLbl.BackgroundTransparency = 1
	clearBtnLbl.Text = "Limpiar"
	clearBtnLbl.TextColor3 = th.subtext
	clearBtnLbl.TextSize = 14
	clearBtnLbl.Font = Enum.Font.GothamSemibold
	clearBtnLbl.TextXAlignment = Enum.TextXAlignment.Left
	clearBtnLbl.Parent = clearBtn
	table.insert(reg.subtexts, clearBtnLbl)

	clearBtn.MouseEnter:Connect(function() TweenService:Create(clearBtn, twI, {BackgroundTransparency=0}):Play() end)
	clearBtn.MouseLeave:Connect(function() TweenService:Create(clearBtn, twI, {BackgroundTransparency=0.15}):Play() end)

	execBtn.MouseButton1Click:Connect(function()
		local code = codeBox.Text
		if code == "" then
			statusDot.BackgroundColor3 = Color3.fromRGB(255,180,0)
			statusLbl.Text = "No hay codigo para ejecutar."
			return
		end
		local ok, err = pcall(function() loadstring(code)() end)
		if ok then
			statusDot.BackgroundColor3 = T().accent
			statusLbl.Text = "Ejecutado correctamente."
		else
			statusDot.BackgroundColor3 = T().danger
			statusLbl.Text = "Error: "..(tostring(err):sub(1,60))
		end
		task.delay(4, function()
			if statusDot and statusDot.Parent then
				statusDot.BackgroundColor3 = T().subtext
				statusLbl.Text = "Listo."
			end
		end)
	end)

	clearBtn.MouseButton1Click:Connect(function()
		codeBox.Text = ""
		execTabData[activeExecTabIdx].content = ""
		statusDot.BackgroundColor3 = T().subtext
		statusLbl.Text = "Editor limpiado."
		task.delay(2, function() if statusLbl and statusLbl.Parent then statusLbl.Text = "Listo." end end)
	end)
end

